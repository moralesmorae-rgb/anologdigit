<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Evaluaciones 2026 - Profesor Eduardo</title>
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@500;700;900&display=swap" rel="stylesheet">
    <style>
        :root {
            /* COLORES MODO OSCURO / ALTO CONTRASTE */
            --primary-color: #000000;
            --primary-dark: #111111;
            --secondary-color: #ffcc00; /* Amarillo vistoso */
            --bg-color: #0a0a0a;
            --card-bg: rgba(20, 20, 20, 0.85);
            --text-color: #ffffff;
            --text-muted: #a1a1aa;
            --success-color: #22c55e;
            --error-color: #ef4444;
        }

        body {
            font-family: 'Quicksand', 'Segoe UI', system-ui, sans-serif;
            /* Fondo oscuro con textura sutil o gradiente */
            background: linear-gradient(-45deg, #0f0f0f, #1a1a1a, #050505, #111111);
            background-size: 400% 400%;
            animation: gradientBg 15s ease infinite;
            color: var(--text-color);
            margin: 0;
            padding: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
        }

        @keyframes gradientBg {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        /* ENCABEZADO MEJORADO CON CONTRASTE OSCURO/AMARILLO */
        header {
            background: var(--primary-color);
            color: var(--text-color);
            width: 100%;
            padding: 18px 0;
            box-shadow: 0 4px 20px rgba(255, 204, 0, 0.1);
            border-bottom: 3px solid var(--secondary-color);
            z-index: 10;
        }

        .header-container {
            max-width: 600px;
            width: 90%;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 12px;
        }

        .brand-layout {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .brand-layout img {
            height: 38px;
            width: auto;
            object-fit: contain;
            border-radius: 6px;
        }

        .brand-layout span {
            font-weight: 900;
            font-size: 1.25rem;
            letter-spacing: 0.5px;
            color: var(--secondary-color);
        }

        .title-layout {
            text-align: right;
        }

        .title-layout h1 { 
            margin: 0; 
            font-size: 1.35rem; 
            font-weight: 900;
        }
        
        .title-layout p { 
            margin: 3px 0 0 0; 
            font-size: 0.85rem; 
            font-weight: 700;
            color: var(--text-muted); 
        }

        @media (max-width: 480px) {
            .header-container { flex-direction: column; text-align: center; }
            .title-layout { text-align: center; }
        }

        /* CONTENEDOR CENTRAL - GLASSMORPHISM OSCURO */
        .container {
            width: 90%;
            max-width: 550px;
            margin: 30px 0;
            padding: 20px 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card {
            background-color: var(--card-bg);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-radius: 24px;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
            padding: 45px 35px;
            width: 100%;
            box-sizing: border-box;
            text-align: center;
            border: 1px solid rgba(255, 204, 0, 0.2);
            animation: cardEntrance 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            position: relative;
            overflow: hidden;
        }

        .card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 6px;
            background: var(--secondary-color);
            box-shadow: 0 0 15px var(--secondary-color);
        }

        @keyframes cardEntrance {
            from { opacity: 0; transform: translateY(20px) scale(0.96); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }

        h2 { 
            color: var(--secondary-color); 
            margin-top: 0; 
            font-size: 2rem;
            font-weight: 900;
            margin-bottom: 12px;
            letter-spacing: -0.5px;
            text-shadow: 0 0 10px rgba(255, 204, 0, 0.3);
        }

        .card p {
            color: #d4d4d8;
            font-size: 1.05rem;
            font-weight: 500;
            line-height: 1.6;
            margin-bottom: 35px;
        }

        /* DOS OPCIONES DE INGRESO PRINCIPALES */
        .options-list {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .btn-link {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            background: transparent;
            border: 2px solid var(--secondary-color);
            padding: 18px 20px;
            border-radius: 12px;
            font-size: 1.2rem;
            font-weight: 900;
            text-decoration: none;
            color: var(--secondary-color);
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .btn-link:hover {
            background: var(--secondary-color);
            color: var(--primary-color);
            transform: translateY(-4px) scale(1.02);
            box-shadow: 0 10px 25px rgba(255, 204, 0, 0.4);
        }

        .btn-home {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-top: 35px;
            color: var(--text-muted);
            text-decoration: none;
            font-weight: 700;
            font-size: 0.95rem;
            padding: 8px 18px;
            border-radius: 50px;
            transition: all 0.2s ease;
            border: 1px solid transparent;
        }
        
        .btn-home:hover { 
            color: var(--text-color);
            background-color: rgba(255, 255, 255, 0.1);
            border-color: rgba(255, 255, 255, 0.2);
        }

